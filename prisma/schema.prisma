generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Property {
  id          String   @id @default(cuid())
  code        String   @unique
  name        String?
  address     String?
  description String?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  contracts Contract[]
}

model ContractCounter {
  year Int @id
  last Int @default(0)
}

enum ContractType {
  PERSON
  COMPANY
}

enum Gender {
  MALE
  FEMALE
}

enum CompanyKind {
  COMPANY
  IP
}

model Tenant {
  id String @id @default(cuid())

  fio              String
  gender           Gender?
  birthDate        DateTime?
  passportSeries   String?
  passportNumber   String?
  passportIssuedBy String?
  passportCode     String?
  passportIssuedAt DateTime?
  regAddress       String?
  signInitials     String?
  signSurname      String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  contracts Contract[]
}

model Company {
  id String @id @default(cuid())

  kind                     CompanyKind @default(COMPANY)
  name                     String
  shortName                String?
  inn                      String?
  kpp                      String?
  ogrn                     String?
  address                  String?
  postalAddress            String?
  email                    String?
  phone                    String?
  bankName                 String?
  bankBik                  String?
  bankAccount              String?
  correspondentAccount     String?
  directorName             String?
  directorPosition         String?
  directorGender           Gender?
  basis                    String?
  directorPositionGenitive String?
  directorNameGenitive     String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  contracts Contract[]

  @@index([name])
}

model Contract {
  id String @id @default(cuid())

  number String @unique
  year   Int
  seq    Int

  type ContractType

  propertyId      String?
  property        Property? @relation(fields: [propertyId], references: [id])
  propertyCode    String
  propertyName    String?
  propertyAddress String?

  tenantId String?
  tenant   Tenant? @relation(fields: [tenantId], references: [id])

  companyId String?
  company   Company? @relation(fields: [companyId], references: [id])

  checkIn      DateTime
  checkOut     DateTime
  contractDate DateTime?
  actDate      DateTime?
  invoiceDate  DateTime?

  pricePerDayRub Int @default(0)
  priceRub       Int

  tenantName     String?
  tenantPassport String?
  tenantAddress  String?

  companyKind                     CompanyKind?
  companyName                     String?
  companyShortName                String?
  companyInn                      String?
  companyKpp                      String?
  companyOgrn                     String?
  companyAddress                  String?
  companyPostalAddress            String?
  companyEmail                    String?
  companyPhone                    String?
  companyBankName                 String?
  companyBankBik                  String?
  companyBankAccount              String?
  companyCorrespondentAccount     String?
  companyDirectorName             String?
  companyDirectorPosition         String?
  companyDirectorGender           Gender?
  companyBasis                    String?
  companyDirectorPositionGenitive String?
  companyDirectorNameGenitive     String?
  companyGuestText                String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([year, seq])
  @@index([companyId])
  @@index([propertyId])
}
